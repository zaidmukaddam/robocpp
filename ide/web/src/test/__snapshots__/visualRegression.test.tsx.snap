exports[`visual regression snapshots > renders the graph property panel empty state consistently 1`] = `"<aside class="graph-property-panel" aria-label="Graph properties"><p class="graph-property-empty">Select a rung element, network node, or SFC step to edit properties.</p></aside>"`;

exports[`visual regression snapshots > renders the narrow viewport gate consistently 1`] = `"<div class="narrow-viewport-gate" role="status"><strong>RoboC++ Studio needs a wider screen</strong><p>This IDE is designed for desktop workbench use. Resize the window to at least 960px wide or use a larger display to edit PLC projects comfortably.</p></div>"`;
